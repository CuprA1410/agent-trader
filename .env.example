# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Exchange (BitGet) ─────────────────────────────────────────────────────────
EXCHANGE=bitget
EXCHANGE_API_KEY=your_bitget_api_key
EXCHANGE_SECRET_KEY=your_bitget_secret
EXCHANGE_PASSPHRASE=your_bitget_passphrase
EXCHANGE_DEMO=true
TRADE_MODE=futures
FUTURES_LEVERAGE=5

# ── Portfolio & Risk ──────────────────────────────────────────────────────────
PORTFOLIO_VALUE_USD=1000
RISK_PCT=0.01
MAX_POSITIONS=10
DRAWDOWN_LIMIT_PCT=0.10

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Storage ───────────────────────────────────────────────────────────────────
LOG_DIR=data
